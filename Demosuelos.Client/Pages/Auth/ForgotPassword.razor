@page "/forgot-password"
@using Demosuelos.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Recuperar contrasena</PageTitle>

<div class="auth-page-shell">
    <div class="auth-card">
        <div class="auth-card-header">
            <p class="auth-kicker">Seguridad</p>
            <h3>Recuperar contrasena</h3>
            <p class="auth-subtitle">Define una nueva contrasena para el usuario indicado.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-success">@message</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <InputText class="form-control" @bind-Value="model.Email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Nueva contrasena</label>
                <InputText type="password" class="form-control" @bind-Value="model.NewPassword" />
                <ValidationMessage For="@(() => model.NewPassword)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmacion</label>
                <InputText type="password" class="form-control" @bind-Value="model.ConfirmPassword" />
                <ValidationMessage For="@(() => model.ConfirmPassword)" />
            </div>

            <button class="btn btn-primary w-100" type="submit" disabled="@sending">
                @(sending ? "Actualizando..." : "Actualizar contrasena")
            </button>
        </EditForm>

        <div class="auth-support-link">
            <a href="login">Volver a iniciar sesion</a>
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordDTO model = new();
    private string? errorMessage;
    private string? message;
    private bool sending;

    private async Task SubmitAsync()
    {
        errorMessage = null;
        message = null;
        sending = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/accounts/forgotpassword", model);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                return;
            }

            message = "La contrasena fue actualizada. Ya puedes iniciar sesion.";
            model.NewPassword = string.Empty;
            model.ConfirmPassword = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al actualizar la contrasena: {ex.Message}";
        }
        finally
        {
            sending = false;
        }
    }
}
